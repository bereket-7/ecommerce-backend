generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  pending
  processing
  delivered
  cancelled
}

enum PaymentStatus {
  pending
  paid
  failed
}

enum PaymentMethod {
  telebirr
  cbe
  cash
}

enum ShippingMethodId {
  addis_standard
  addis_express
  other_cities
}

enum OrderAddressType {
  billing
  shipping
}

enum DiscountType {
  percent
  fixed
}

model Category {
  id        Int       @id @default(autoincrement())
  slug      String    @unique
  name      String
  imagePath String?   @map("image_path")
  sortOrder Int       @default(0) @map("sort_order")
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("categories")
}

model Product {
  id              Int            @id @default(autoincrement())
  slug            String         @unique
  title           String
  description     String         @db.Text
  price           Int
  discountedPrice Int            @map("discounted_price")
  reviewCount     Int            @default(0) @map("review_count")
  categoryId      Int            @map("category_id")
  category        Category       @relation(fields: [categoryId], references: [id])
  brand           String?
  material        String?
  colors          Json?
  setOptions      Json?          @map("set_options")
  specs           Json?
  imgs            Json?
  stock           Int            @default(100)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  orderLines      OrderLine[]
  reviews         Review[]
  wishlistItems   WishlistItem[]

  @@map("products")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String         @map("password_hash")
  name          String?
  phone         String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  @@map("users")
}

model Address {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String?
  name      String
  phone     String
  city      String
  street    String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("addresses")
}

model Order {
  id               String           @id @default(cuid())
  orderNumber      String           @unique @map("order_number")
  status           OrderStatus      @default(pending)
  paymentStatus    PaymentStatus    @default(pending) @map("payment_status")
  paymentMethod    PaymentMethod    @map("payment_method")
  shippingMethodId ShippingMethodId @map("shipping_method_id")
  subtotal         Int
  shippingFee      Int              @map("shipping_fee")
  discountAmount   Int              @default(0) @map("discount_amount")
  total            Int
  notes            String?
  guestEmail       String?          @map("guest_email")
  guestPhone       String?          @map("guest_phone")
  userId           String?          @map("user_id")
  user             User?            @relation(fields: [userId], references: [id])
  couponCode       String?          @map("coupon_code")
  lines            OrderLine[]
  addresses        OrderAddress[]
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@map("orders")
}

model OrderLine {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id])
  title     String
  quantity  Int
  unitPrice Int     @map("unit_price")
  lineTotal Int     @map("line_total")

  @@map("order_lines")
}

model OrderAddress {
  id      String           @id @default(cuid())
  orderId String           @map("order_id")
  order   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type    OrderAddressType
  name    String
  phone   String
  email   String?
  city    String
  street  String

  @@unique([orderId, type])
  @@map("order_addresses")
}

model WishlistItem {
  id        String  @id @default(cuid())
  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model Coupon {
  id          String       @id @default(cuid())
  code        String       @unique
  discountType DiscountType @map("discount_type")
  value       Int
  minSubtotal Int?         @map("min_subtotal")
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("coupons")
}

model Review {
  id         String   @id @default(cuid())
  productId  Int      @map("product_id")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  authorName String   @map("author_name")
  rating     Int
  body       String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("reviews")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  subject   String
  phone     String
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletter_subscribers")
}
